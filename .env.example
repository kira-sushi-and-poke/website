# Square API Configuration
# Get these from https://developer.squareup.com/apps

# Server-only access token (NEVER expose to client, no NEXT_PUBLIC_ prefix)
ACCESS_TOKEN=your_square_access_token_here

# Location ID for your Square location
LOCATION_ID=your_square_location_id_here

# API Base URL (use sandbox for testing, production for live)
# Sandbox: https://connect.squareupsandbox.com
# Production: https://connect.squareup.com
API_BASE_URL=https://connect.squareupsandbox.com

# Square API Endpoints
API_CATALOG_URL=https://connect.squareupsandbox.com/v2/catalog
API_ORDERS_URL=https://connect.squareupsandbox.com/v2/orders
API_PAYMENT_LINKS_URL=https://connect.squareupsandbox.com/v2/online-checkout/payment-links
API_CUSTOMERS_URL=https://connect.squareupsandbox.com/v2/customers
API_PAYMENTS_URL=https://connect.squareupsandbox.com/v2/payments

# Site URL for redirects (update for production)
SITE_URL=http://localhost:3000

# Public environment variables (exposed to browser)
NEXT_PUBLIC_SQUARE_APP_ID=your_square_app_id_here
NEXT_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id_here

# Webhook Configuration (optional, for payment webhooks)
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key_here

# Node Environment
# Development: development
# Production: production
NODE_ENV=development
